# Backend (Express) Environment Variables
NODE_ENV=production

# PostgreSQL (Preferred for production)
# DATABASE_URL=postgres://user:password@host:port/dbname

# PostgreSQL (Alternative for local dev)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=yoto
DB_USER=postgres
DB_PASSWORD=

# Auth
JWT_SECRET=change-this-to-a-random-string

# Server
PORT=4000

# CORS — URL of the frontend
FRONTEND_URL=http://localhost:3000
